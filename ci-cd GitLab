# Docker Compose

Create:

```bash
nano docker-compose.yaml
```

```yaml
services:

  gitlab:
    image: gitlab/gitlab-ce:latest
    container_name: gitlab-loc
    restart: unless-stopped
    hostname: gitlab.docker.loc

    shm_size: "512m"

    environment:
      GITLAB_OMNIBUS_CONFIG: |

        external_url 'https://gitlab.docker.loc'

        letsencrypt['enable'] = false

        nginx['redirect_http_to_https'] = true

        nginx['ssl_certificate'] = "/etc/gitlab/ssl/gitlab.docker.loc.crt"
        nginx['ssl_certificate_key'] = "/etc/gitlab/ssl/gitlab.docker.loc.key"

        registry_external_url 'https://registry.docker.loc'

        gitlab_rails['registry_enabled'] = true
        gitlab_rails['registry_host'] = "registry.docker.loc"

        registry['enable'] = true
        registry['registry_http_addr'] = "127.0.0.1:5000"

        registry_nginx['enable'] = true
        registry_nginx['listen_port'] = 443

        registry_nginx['ssl_certificate'] = "/etc/gitlab/ssl/registry.docker.loc.crt"
        registry_nginx['ssl_certificate_key'] = "/etc/gitlab/ssl/registry.docker.loc.key"

        prometheus_monitoring['enable'] = false

    ports:
      - "80:80"
      - "443:443"
      - "2222:22"

    volumes:
      - ./config:/etc/gitlab
      - ./logs:/var/log/gitlab
      - ./data:/var/opt/gitlab

    networks:
      gitlab-net:
        aliases:
          - gitlab.docker.loc
          - registry.docker.loc

  runner:
    image: gitlab/gitlab-runner:alpine
    container_name: runner-loc
    restart: unless-stopped

    depends_on:
      - gitlab

    volumes:
      - ./runner/config:/etc/gitlab-runner
      - ./runner/certs:/etc/gitlab-runner/certs:ro
      - /var/run/docker.sock:/var/run/docker.sock

    networks:
      - gitlab-net

networks:
  gitlab-net:
    driver: bridge
```

