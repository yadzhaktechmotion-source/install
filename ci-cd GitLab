# Create Local Certificate Authority

```bash
openssl genrsa -out local-ca.key 4096
```

```bash
openssl req \
-x509 \
-new \
-nodes \
-key local-ca.key \
-sha256 \
-days 3650 \
-out local-ca.crt \
-subj "/CN=Yadzhak Local GitLab CA"
```

---

# Create GitLab Certificate

Create SAN config:

```bash
cat > gitlab-san.cnf <<EOF
[req]
distinguished_name=req
x509_extensions=v3_req
prompt=no

[req_distinguished_name]
CN=gitlab.docker.loc

[v3_req]
subjectAltName=@alt_names

[alt_names]
DNS.1=gitlab.docker.loc
IP.1=192.168.1.50
EOF
```

Generate key:

```bash
openssl genrsa \
-out config/ssl/gitlab.docker.loc.key 4096
```

Generate CSR:

```bash
openssl req \
-new \
-key config/ssl/gitlab.docker.loc.key \
-out gitlab.docker.loc.csr \
-subj "/CN=gitlab.docker.loc"
```

Sign certificate:

```bash
openssl x509 \
-req \
-in gitlab.docker.loc.csr \
-CA local-ca.crt \
-CAkey local-ca.key \
-CAcreateserial \
-out config/ssl/gitlab.docker.loc.crt \
-days 825 \
-sha256 \
-extfile gitlab-san.cnf \
-extensions v3_req
```

