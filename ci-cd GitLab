# Create Registry Certificate

Create SAN config:

```bash
cat > registry-san.cnf <<EOF
[req]
distinguished_name=req
x509_extensions=v3_req
prompt=no

[req_distinguished_name]
CN=registry.docker.loc

[v3_req]
subjectAltName=@alt_names

[alt_names]
DNS.1=registry.docker.loc
IP.1=192.168.1.50
EOF
```

Generate key:

```bash
openssl genrsa \
-out config/ssl/registry.docker.loc.key 4096
```

Generate CSR:

```bash
openssl req \
-new \
-key config/ssl/registry.docker.loc.key \
-out registry.docker.loc.csr \
-subj "/CN=registry.docker.loc"
```

Sign certificate:

```bash
openssl x509 \
-req \
-in registry.docker.loc.csr \
-CA local-ca.crt \
-CAkey local-ca.key \
-CAcreateserial \
-out config/ssl/registry.docker.loc.crt \
-days 825 \
-sha256 \
-extfile registry-san.cnf \
-extensions v3_req
```

